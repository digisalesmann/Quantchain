# Copy this to .env for local dev, or paste the equivalent values into your
# hosting platform's environment variable settings for production.

# --- Database (Postgres) ---
# Local: the podman/docker container started for dev.
# Production (Supabase): Project Settings -> Database -> Connection string.
#   DATABASE_URL = the "Transaction" pooler URL (port 6543, ?pgbouncer=true) — used at runtime.
#   DIRECT_URL   = the direct connection URL (port 5432) — used only by `prisma migrate`.
DATABASE_URL="postgresql://investment:investment@127.0.0.1:5432/investment"
DIRECT_URL="postgresql://investment:investment@127.0.0.1:5432/investment"

# --- Redis ---
# Local: the podman/docker container started for dev.
# Production (Upstash): Database -> "Redis Connect" -> ioredis / Node tab, the rediss:// URL.
REDIS_URL="redis://127.0.0.1:6379"

# --- Auth ---
# Generate a strong random value for production, e.g.: openssl rand -base64 48
JWT_SECRET="dev-secret-change-in-production"

# --- WebAuthn (passkeys) ---
# Production: RP_ID is the bare domain (no scheme/port) the app is served from,
# e.g. quantchain.vercel.app. ORIGIN is the full https:// URL of that same domain.
WEBAUTHN_RP_NAME="Quantchain"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"

# --- Standalone WebSocket server (server/ws-server.ts) ---
# Local only — the dev server binds to this fixed port. In production (Render) the
# platform injects its own PORT env var, which the server prefers automatically.
WS_PORT=4001
# Local only — the browser builds ws://<hostname>:<port> from this. In production set
# NEXT_PUBLIC_WS_URL instead (see below), since the WS server lives on a different host.
NEXT_PUBLIC_WS_PORT=4001
# Production only — full cross-origin URL of the deployed WS server, e.g.:
# NEXT_PUBLIC_WS_URL="wss://quantchain-ws.onrender.com"

# --- Misc ---
# Production: the full https:// URL of the deployed Next.js app (used to build the
# Google OAuth callback URL).
APP_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
